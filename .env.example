# ══════════════════════════════════════════════════════
# IPL Prediction AI Agent - Environment Variables
# ══════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit the .env file to Git (it's in .gitignore)

# OpenWeatherMap API Key (get free at https://openweathermap.org/api)
WEATHER_API_KEY=your_openweathermap_api_key_here

# Database (optional - uses SQLite by default)
# DATABASE_URL=postgresql://user:password@localhost:5432/ipl_predictions

# Twitter/X API (optional - for sentiment analysis in v2.0)
# TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# MLflow Tracking (optional - defaults to local ./mlruns)
# MLFLOW_TRACKING_URI=http://localhost:5000
